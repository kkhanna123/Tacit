        { "type": "required_concepts", "concepts": ["confidence", "source limitation"] },
        { "type": "no_empty_output", "min_words": 60 },
        { "type": "context_budget", "max_prompt_tokens": 1500 }
      ]
    },
    "cases": [
      {
        "id": "case_memo_basic",
        "name": "client_ready_memo_bullets_basic",
